# Copy to .env and adjust. Default provider 'fake' needs nothing here.
LLM_PROVIDER=fake

# --- Azure OpenAI (LLM_PROVIDER=azure) — auth via DefaultAzureCredential (no key) ---
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small
# Optional: user-assigned managed identity client id
# AZURE_MANAGED_IDENTITY_CLIENT_ID=

# --- OpenAI-compatible (LLM_PROVIDER=openai_compatible) ---
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Supabase ---
# Public (also used by the Flutter app):
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# SECRET — worker writes bypass RLS. Never commit. Set locally / in CI secrets / Key Vault:
SUPABASE_SERVICE_ROLE_KEY=
# SECRET — optional pooled Postgres connection string (port 6543):
DATABASE_URL=

# --- GitHub OAuth ---
# Enter these in Supabase: Auth -> Providers -> GitHub (from your GitHub OAuth App).
# Kept here for reference; the worker itself only needs the Supabase keys above.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
